{
  "plugin": {
    "name": "Escher Pitch Shifter",
    "version": "1.0.0",
    "vendor": "AgentVST",
    "category": "Effect"
  },
  "parameters": [
    {
      "id": "shift_cycle",
      "name": "Shift Cycle",
      "type": "float",
      "min": 0.05,
      "max": 10.0,
      "default": 0.5,
      "unit": "Hz",
      "step": 0.01,
      "skew": 0.5
    },
    {
      "id": "tension_lock",
      "name": "Tension/Lock",
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 0.0,
      "unit": "ratio",
      "step": 0.01,
      "skew": 1.0
    },
    {
      "id": "asymmetry",
      "name": "Asymmetry",
      "type": "float",
      "min": -1.0,
      "max": 1.0,
      "default": 0.0,
      "unit": "skew",
      "step": 0.01,
      "skew": 1.0
    },
    {
      "id": "mix",
      "name": "Dry/Wet Mix",
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 1.0,
      "unit": "ratio",
      "step": 0.01,
      "skew": 1.0
    }
  ],
  "dsp_routing": [
    {
      "source": "input",
      "destination": "escher_shifter",
      "parameter_link": {
        "shift_cycle": "escher_shifter.rate",
        "tension_lock": "escher_shifter.lock",
        "asymmetry": "escher_shifter.asymmetry",
        "mix": "escher_shifter.mix"
      }
    },
    {
      "source": "escher_shifter",
      "destination": "output"
    }
  ]
}