{
  "plugin": {
    "name": "IntermodulationWallGenerator",
    "version": "1.0.0",
    "vendor": "AgentVST",
    "category": "Fx"
  },
  "parameters": [
    {
      "id": "swell_time",
      "name": "Swell Time",
      "type": "float",
      "min": 10.0,
      "max": 5000.0,
      "default": 1000.0,
      "unit": "ms",
      "step": 1.0,
      "group": "reverb"
    },
    {
      "id": "wall_density",
      "name": "Wall Density",
      "type": "float",
      "min": 0.0,
      "max": 100.0,
      "default": 50.0,
      "unit": "%",
      "step": 1.0,
      "group": "distortion"
    },
    {
      "id": "breathing_gate",
      "name": "Breathing Gate",
      "type": "float",
      "min": 0.0,
      "max": 100.0,
      "default": 25.0,
      "unit": "%",
      "step": 1.0,
      "group": "dynamics"
    },
    {
      "id": "bypass",
      "name": "Bypass",
      "type": "boolean",
      "default": false,
      "group": "output"
    }
  ],
  "groups": [
    {
      "id": "reverb",
      "name": "Swell Reverb",
      "parameters": [
        "swell_time"
      ]
    },
    {
      "id": "distortion",
      "name": "Limiter/Clipper",
      "parameters": [
        "wall_density"
      ]
    },
    {
      "id": "dynamics",
      "name": "Sidechain Gate",
      "parameters": [
        "breathing_gate"
      ]
    },
    {
      "id": "output",
      "name": "Output",
      "parameters": [
        "bypass"
      ]
    }
  ]
}