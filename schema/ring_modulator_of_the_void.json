{
  "plugin": {
    "name": "Ring Modulator of the Void",
    "version": "1.0.0",
    "vendor": "AgentVST",
    "category": "Modulation"
  },
  "parameters": [
    {
      "id": "inharmonicity",
      "name": "Inharmonicity Level",
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 0.5,
      "unit": "ratio",
      "step": 0.01,
      "skew": 1.0,
      "group": "modulation"
    },
    {
      "id": "carrier_drift",
      "name": "Carrier Drift",
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 0.1,
      "unit": "ratio",
      "step": 0.01,
      "skew": 1.0,
      "group": "modulation"
    },
    {
      "id": "tracking_speed",
      "name": "Tracking Speed",
      "type": "float",
      "min": 10.0,
      "max": 500.0,
      "default": 50.0,
      "unit": "ms",
      "step": 1.0,
      "skew": 0.5,
      "group": "envelope"
    },
    {
      "id": "bypass",
      "name": "Bypass",
      "type": "boolean",
      "default": false,
      "group": "output"
    }
  ],
  "groups": [
    {
      "id": "modulation",
      "name": "Modulation",
      "parameters": [
        "inharmonicity",
        "carrier_drift"
      ]
    },
    {
      "id": "envelope",
      "name": "Envelope",
      "parameters": [
        "tracking_speed"
      ]
    },
    {
      "id": "output",
      "name": "Output",
      "parameters": [
        "bypass"
      ]
    }
  ]
}