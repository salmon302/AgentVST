{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "plugin": {
    "name": "Dechronicization_Engine",
    "version": "1.0.0",
    "vendor": "AgentVST Suite 2",
    "category": "Fx",
    "description": "Reverse polyrhythmic pre-echo engine destroying linear time."
  },
  "parameters": [
    {
      "id": "pre_cognition",
      "name": "Pre-Cognition",
      "type": "float",
      "min": 100.0,
      "max": 2000.0,
      "default": 500.0,
      "unit": "ms"
    },
    {
      "id": "temporal_conflict",
      "name": "Temporal Conflict",
      "type": "float",
      "min": 0.25,
      "max": 4.0,
      "default": 1.0,
      "unit": "ratio"
    },
    {
      "id": "ghost_mix",
      "name": "Ghost Mix",
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 0.5,
      "unit": "wet"
    }
  ]
}