      "name": "Sob Depth",
      "type": "float",
      "min": 0.0,
      "max": 100.0,
      "default": 45.0,
      "unit": "%",
      "step": 0.1,
      "skew": 1.0,
      "group": "lacrimosa"
    },
    {
